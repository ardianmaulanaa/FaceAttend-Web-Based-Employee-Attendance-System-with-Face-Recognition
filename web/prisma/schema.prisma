// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id                   String   @id @default(uuid()) @db.Char(36)
  name                 String   @db.VarChar(100)
  email                String   @unique @db.VarChar(100)
  password_hash        String   @db.VarChar(255)
  role                 String   @default("employee") @db.VarChar(20)
  department           String?  @db.VarChar(100)
  position             String?  @db.VarChar(100)
  phone                String?  @db.VarChar(20)
  status               String   @default("active") @db.VarChar(20)

  // Foto profil karyawan
  profile_photo        String?  @db.VarChar(255)

  must_change_password Boolean  @default(true)
  created_at           DateTime @default(now())

  // Dibuat default supaya data user lama tidak error saat migrate
  updated_at           DateTime @default(now()) @updatedAt

  attendances Attendance[]

  @@map("users")
}

model Attendance {
  id String @id @default(uuid()) @db.Char(36)

  userId String @db.Char(36)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Waktu absen
  checkInTime  DateTime?
  checkOutTime DateTime?

  // Foto bukti absen disimpan langsung ke database sebagai BLOB
  checkInPhoto  Bytes?
  checkOutPhoto Bytes?

  // Tipe file foto, contoh: image/jpeg atau image/png
  checkInPhotoMime  String? @db.VarChar(50)
  checkOutPhotoMime String? @db.VarChar(50)

  // Lokasi GPS saat check-in
  checkInLatitude  Float?
  checkInLongitude Float?

  // Lokasi GPS saat check-out
  checkOutLatitude  Float?
  checkOutLongitude Float?

  status AttendanceStatus @default(CHECKED_IN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AttendanceStatus {
  CHECKED_IN
  CHECKED_OUT
}